FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 方式 1：写入已有新版飞书文档 docx
FEISHU_DOCUMENT_ID=xxx

# 可选：默认用 document_id 作为父 block。若写入失败，填具体父 block_id。
FEISHU_PARENT_BLOCK_ID=

# 可选：插入位置，0 表示写到文档开头。
FEISHU_INSERT_INDEX=0

# 方式 2：不填 FEISHU_DOCUMENT_ID 时，使用文件夹 token 创建新文档。
FEISHU_FOLDER_TOKEN=
FEISHU_DOCUMENT_TITLE=轻醒小红书短视频商单脚本

# 推荐优先使用 larksuite/cli。真实 App Secret 不要提交到 GitHub。
